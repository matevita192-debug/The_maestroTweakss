# Funzione per creare pulsanti di menu laterale
function Add-MenuButton($title, $index, $tp) {
    $btn = New-Object System.Windows.Forms.Button
    $btn.Text = $title
    $btn.Location = New-Object System.Drawing.Point(10, (50 + ($index * 60)))
    $btn.Size = New-Object System.Drawing.Size(130, 50)
    $btn.FlatStyle = "Flat"
    $btn.FlatAppearance.BorderSize = 0
    $btn.Font = $fontTabs
    $btn.ForeColor = "White"
    $btn.Cursor = "Hand"
    $btn.Add_Click({ $tabControl.SelectedTab = $tp })
    $pnlTabs.Controls.Add($btn)
    return $btn
}

# --- CREAZIONE SCHEDE (Tabs) ---
function Add-CyberTab($title) {
    $tp = New-Object System.Windows.Forms.TabPage
    $tp.Text = $title
    $tp.BackColor = [System.Drawing.Color]::FromArgb(10, 10, 10)
    $tabControl.TabPages.Add($tp)
    return $tp
}

