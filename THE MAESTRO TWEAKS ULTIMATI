# --- AZIONE TASTO APPLY ---
$btnRun.Add_Click({
    Write-Host "`n[!] PROTOCOLLO OMNI_OVERHAUL ATTIVATO. GUARDA IL LOG." -ForegroundColor Magenta
    Start-Sleep -Seconds 1
    
    # PULIZIA FINALE ERRORI
    $ErrorActionPreference = "SilentlyContinue"

    # PUNTO DI RIPRISTINO
    Write-Host "[-] Creazione Scudo di Sistema (Restore Point)..." -ForegroundColor Yellow
    Checkpoint-Computer -Description "MAESTRO_OMNI_BACKUP" -RestorePointType "MODIFY_SETTINGS" -ErrorAction SilentlyContinue

    # 1. PERFORMANCE OVERRIDE
    if ($c_ultimate.Checked) {
        Write-Host ">> Iniezione Energia... [Bypass Throttling]" -ForegroundColor Cyan
        powercfg -duplicatescheme e9a42b02-d5df-448d-aa00-03f14749eb61 | Out-Null
        powercfg -setactive e9a42b02-d5df-448d-aa00-03f14749eb61 | Out-Null
        # Disable Power Throttling
        reg add "HKLM\System\CurrentControlSet\Control\Power\PowerThrottling" /v "PowerThrottlingOff" /t REG_DWORD /d 1 /f | Out-Null
    }
    
    if ($c_lag.Checked) {
        Write-Host ">> Distruzione Latenza..." -ForegroundColor Cyan
        reg add "HKLM\SYSTEM\CurrentControlSet\Services\mouclass\Parameters" /v "MouseDataQueueSize" /t REG_DWORD /d 20 /f | Out-Null
        reg add "HKLM\SYSTEM\CurrentControlSet\Services\kbdclass\Parameters" /v "KeyboardDataQueueSize" /t REG_DWORD /d 20 /f | Out-Null
    }

    # 2. PROCESS KILLER (NUCLEAR)
    if ($c_ct.Checked) {
        Write-Host ">> ESECUZIONE MASSACRO PROCESSI (CT Style)..." -ForegroundColor Red
        $svcs = @("DiagTrack", "dmwappushservice", "SysMain", "WbioSrvc", "MapsBroker", "XblAuthManager", "XblGameSave", "XboxNetApiSvc", "Spooler")
        foreach ($s in $svcs) {
            Write-Host "   > Terminando parassita: $s" -ForegroundColor DarkGray
            Stop-Service -Name $s -Force | Out-Null
            Set-Service -Name $s -StartupType Disabled | Out-Null
        }
        # Disabilita Scheduled Tasks che Chris Titus odia
        Write-Host ">> Disabilitando Task di Manutenzione..." -ForegroundColor Yellow
        Get-ScheduledTask -TaskName "Consolidator", "ProgramDataUpdater", "Proxy" | Disable-ScheduledTask | Out-Null
    }

    if ($c_tele.Checked) {
        Write-Host ">> Eradicazione Telemetria..." -ForegroundColor Yellow
        reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\DataCollection" /v "AllowTelemetry" /t REG_DWORD /d 0 /f | Out-Null
    }

    if ($c_deep.Checked) {
        Write-Host ">> Disabilitando manutenzione automatica..." -ForegroundColor Red
        reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Schedule\Maintenance" /v "MaintenanceDisabled" /t REG_DWORD /d 1 /f | Out-Null
    }

    # 3. CLEANER
    if ($c_temp.Checked) {
        Write-Host ">> Bruciando spazzatura profonda..." -ForegroundColor Yellow
        $paths = @("$env:TEMP\*", "C:\Windows\Temp\*", "C:\Windows\Prefetch\*")
        foreach ($p in $paths) {
            Get-ChildItem $p -Recurse | ForEach-Object {
                Remove-Item $_.FullName -Force -Recurse | Out-Null
            }
        }
    }

    Write-Host "`n[COMPLETE]: SISTEMA OTTIMIZZATO AL LIVELLO MAESTRO." -ForegroundColor Lime
    Clear-Host # Pulisce lo schermo anche se ha funzionato
    [System.Windows.Forms.MessageBox]::Show("Rituale Cyber completato con successo. Riavvia il PC e controlla la fluidità.", "The Maestro Omni-Optimizer")
})

