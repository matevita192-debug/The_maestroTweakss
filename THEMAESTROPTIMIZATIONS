Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# --- MESSAGGIO INIZIALE NEL TERMINALE ---
Write-Host "##############################################" -ForegroundColor Cyan
Write-Host "#    THE MAESTRO IS OPTIMIZING YOUR LIFE     #" -ForegroundColor Magenta
Write-Host "##############################################" -ForegroundColor Cyan
Write-Host "In attesa che l'umano faccia le sue scelte..." -ForegroundColor Yellow

$form = New-Object System.Windows.Forms.Form
$form.Text = "MAESTRO'S CHAOS OPTIMIZER"
$form.Size = New-Object System.Drawing.Size(420,550)
$form.BackColor = [System.Drawing.Color]::FromArgb(15, 15, 15)
$form.StartPosition = "CenterScreen"

# Titolo Bizzarro
$label = New-Object System.Windows.Forms.Label
$label.Text = "MAESTRO'S MAGIC"
$label.Font = New-Object System.Drawing.Font("Impact", 26)
$label.ForeColor = [System.Drawing.Color]::Lime
$label.Size = New-Object System.Drawing.Size(350, 50)
$label.Location = New-Object System.Drawing.Point(35, 20)
$label.TextAlign = "MiddleCenter"
$form.Controls.Add($label)

# Checkboxes
$chkFPS = New-Object System.Windows.Forms.CheckBox
$chkFPS.Text = "Inject Ultra-FPS Serum"; $chkFPS.ForeColor = "White"; $chkFPS.Location = New-Object System.Drawing.Point(50, 120); $chkFPS.Size = New-Object System.Drawing.Size(300, 30); $form.Controls.Add($chkFPS)

$chkLag = New-Object System.Windows.Forms.CheckBox
$chkLag.Text = "Exorcise Input Lag"; $chkLag.ForeColor = "White"; $chkLag.Location = New-Object System.Drawing.Point(50, 170); $chkLag.Size = New-Object System.Drawing.Size(300, 30); $form.Controls.Add($chkLag)

$chkClean = New-Object System.Windows.Forms.CheckBox
$chkClean.Text = "Burn Trash Files"; $chkClean.ForeColor = "White"; $chkClean.Location = New-Object System.Drawing.Point(50, 220); $chkClean.Size = New-Object System.Drawing.Size(300, 30); $form.Controls.Add($chkClean)

# Tasto Apply
$btnApply = New-Object System.Windows.Forms.Button
$btnApply.Text = "DO THE MAGIC"; $btnApply.BackColor = [System.Drawing.Color]::Lime; $btnApply.Location = New-Object System.Drawing.Point(110, 350); $btnApply.Size = New-Object System.Drawing.Size(200, 60); $btnApply.Font = New-Object System.Drawing.Font("Segoe UI", 12, [System.Drawing.FontStyle]::Bold)

$btnApply.Add_Click({
    Write-Host "`n[!] AVVIO RITUALE DI OTTIMIZZAZIONE..." -ForegroundColor Magenta
    
    if ($chkFPS.Checked) {
        Write-Host "[-] Sintonizzando i neutroni per il Boost FPS..." -ForegroundColor Cyan
        powercfg -duplicatescheme e9a42b02-d5df-448d-aa00-03f14749eb61
        powercfg -setactive e9a42b02-d5df-448d-aa00-03f14749eb61
        Write-Host "[+] Piano energetico iniettato con successo." -ForegroundColor Green
    }
    
    if ($chkLag.Checked) {
        Write-Host "[-] Cacciando i lag-monsters dal mouse e dalla tastiera..." -ForegroundColor Cyan
        # Tweaks Registro
        Set-ItemProperty -Path "HKCU:\Control Panel\Mouse" -Name "MouseSpeed" -Value 0
        Set-ItemProperty -Path "HKLM:\SYSTEM\CurrentControlSet\Services\mouclass\Parameters" -Name "MouseDataQueueSize" -Value 20
        Set-ItemProperty -Path "HKLM:\SYSTEM\CurrentControlSet\Services\kbdclass\Parameters" -Name "KeyboardDataQueueSize" -Value 20
        Write-Host "[+] Latenza polverizzata." -ForegroundColor Green
    }
    
    if ($chkClean.Checked) {
        Write-Host "[-] Incenerimento file inutili in corso... Ritorna tra poco!" -ForegroundColor Cyan
        $files = Get-ChildItem "$env:TEMP\*" -Recurse
        foreach ($file in $files) {
            Write-Host "Cestinando: $($file.Name)" -ForegroundColor DarkGray
            Remove-Item $file.FullName -Force -ErrorAction SilentlyContinue
        }
        Write-Host "[+] Spazzatura eliminata." -ForegroundColor Green
    }

    Write-Host "`n[***] SCRIPT FINITO. IL TUO PC ORA VOLA. [***]" -ForegroundColor Gold
    [System.Windows.Forms.MessageBox]::Show("Le modifiche sono pronte, babbano! Riavvia il PC e goditi la fluidità.", "The Maestro dice...")
})

$form.Controls.Add($btnApply)
$form.ShowDialog()
