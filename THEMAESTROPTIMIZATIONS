Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing
$ErrorActionPreference = "SilentlyContinue"
Clear-Host

# --- UI SETTINGS ---
$form = New-Object System.Windows.Forms.Form
$form.Text = "MAESTRO NUCLEAR OPTIMIZER"
$form.Size = New-Object System.Drawing.Size(450,550)
$form.BackColor = [System.Drawing.Color]::FromArgb(5, 5, 5)
$form.StartPosition = "CenterScreen"

$label = New-Object System.Windows.Forms.Label
$label.Text = "NUCLEAR MODE"; $label.Font = New-Object System.Drawing.Font("Impact", 35); $label.ForeColor = [System.Drawing.Color]::Red
$label.Size = New-Object System.Drawing.Size(400, 60); $label.Location = New-Object System.Drawing.Point(25, 20); $label.TextAlign = "MiddleCenter"; $form.Controls.Add($label)

$chkNuclear = New-Object System.Windows.Forms.CheckBox; $chkNuclear.Text = "ERADICA PROCESSI (Nuclear)"; $chkNuclear.ForeColor = "Yellow"; $chkNuclear.Font = New-Object System.Drawing.Font("Segoe UI", 12, [System.Drawing.FontStyle]::Bold); $chkNuclear.Location = New-Object System.Drawing.Point(50, 150); $chkNuclear.Size = New-Object System.Drawing.Size(350, 30); $form.Controls.Add($chkNuclear)

$btn = New-Object System.Windows.Forms.Button; $btn.Text = "LAUNCH ATTACK"; $btn.BackColor = [System.Drawing.Color]::Red; $btn.ForeColor = "White"; $btn.Location = New-Object System.Drawing.Point(125, 380); $btn.Size = New-Object System.Drawing.Size(200, 70); $btn.Font = New-Object System.Drawing.Font("Segoe UI", 14, [System.Drawing.FontStyle]::Bold); $btn.FlatStyle = "Flat"

$btn.Add_Click({
    Write-Host "`n[!] NUCLEAR ATTACK INIZIATO. NESSUN PRIGIONIERO." -ForegroundColor Red
    Write-Host "Ritorna tra poco che saranno pronte le modifiche..." -ForegroundColor Cyan

    if ($chkNuclear.Checked) {
        # 1. KILL APPS IN BACKGROUND (Il killer dei processi)
        Write-Host "[-] Bloccando le App di Windows in Background..." -ForegroundColor Yellow
        $RegistryPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\BackgroundAccessApplications"
        if (-not (Test-Path $RegistryPath)) { New-Item $RegistryPath -Force | Out-Null }
        Set-ItemProperty -Path $RegistryPath -Name "GlobalUserDisabled" -Value 1 -Type DWord

        # 2. DISABILITA STARTUP PESANTI (Edge, OneDrive, Cortana)
        Write-Host "[-] Rimozione programmi all'avvio..." -ForegroundColor Red
        $runKeys = @("OneDrive", "MicrosoftEdgeAutoLaunch", "Cortana", "Teams")
        foreach ($key in $runKeys) {
            Remove-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run" -Name $key -ErrorAction SilentlyContinue
        }

        # 3. DISABILITA SERVIZI DI TRACCIAMENTO PROFONDO
        Write-Host "[-] Uccidendo servizi di Telemetria..." -ForegroundColor Yellow
        $services = @("DiagTrack", "dmwappushservice", "SysMain", "WbioSrvc", "MapsBroker", "XblAuthManager", "XblGameSave", "XboxNetApiSvc", "Spooler") # Spooler è la stampante: se non stampi, uccidilo!
        foreach ($s in $services) {
            Stop-Service -Name $s -Force 
            Set-Service -Name $s -StartupType Disabled
        }

        # 4. PULIZIA SCHEDULER (Quello che riapre i processi)
        Write-Host "[-] Distruggendo i Timer di Windows..." -ForegroundColor Red
        Get-ScheduledTask -TaskName "Consolidator", "ProgramDataUpdater", "Proxy", "Microsoft Compatibility Appraiser" | Disable-ScheduledTask

        Write-Host "[+] Tabula Rasa completata." -ForegroundColor Green
    }

    Write-Host "`n[***] SCRIPT FINITO. RIAVVIA ORA. [***]" -ForegroundColor Gold
    [System.Windows.Forms.MessageBox]::Show("Attacco completato. Se dopo il riavvio hai ancora 104 processi, significa che hai troppe app tue (Discord, Steam, ecc.) che partono all'avvio. Chiudile manualmente!", "The Maestro Nuclear")
})

$form.Controls.Add($btn)
$form.ShowDialog() | Out-Null
