$c2 = New-Object System.Windows.Forms.CheckBox; $c2.Text = "FORCE GPU PRIORITY (HAGS)"; $c2.Location = New-Object System.Drawing.Point(30, 80); $c2.Size = New-Object System.Drawing.Size(500, 30); $t1.Controls.Add($c2)
$c3 = New-Object System.Windows.Forms.CheckBox; $c3.Text = "DISABLE CPU CORE PARKING"; $c3.Location = New-Object System.Drawing.Point(30, 120); $c3.Size = New-Object System.Drawing.Size(500, 30); $t1.Controls.Add($c3)

