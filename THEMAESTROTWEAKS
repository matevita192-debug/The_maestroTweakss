function Add-MaestroTab($name) {
    $tp = New-Object System.Windows.Forms.TabPage
    $tp.Text = $name
    $tp.BackColor = [System.Drawing.Color]::FromArgb(15, 15, 20)
    $tabs.TabPages.Add($tp)
    return $tp
}

