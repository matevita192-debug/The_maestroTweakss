# --- BOTTONE DI ESECUZIONE ---
$btnRun = New-Object System.Windows.Forms.Button
$btnRun.Text = "INITIATE SYSTEM OVERHAUL"
$btnRun.Location = New-Object System.Drawing.Point(100, 700)
$btnRun.Size = New-Object System.Drawing.Size(500, 70)
$btnRun.FlatStyle = "Flat"
$btnRun.FlatAppearance.BorderColor = "Cyan"
$btnRun.FlatAppearance.BorderSize = 2
$btnRun.Font = $fontBtn
$btnRun.BackColor = [System.Drawing.Color]::FromArgb(30, 30, 40)
$btnRun.Cursor = "Hand"

$btnRun.Add_Click({
    Write-Host "`n[!] AVVIO PROTOCOLLO OMNI. RESTA IN ATTESA." -ForegroundColor Magenta
    
    # PUNTO DI RIPRISTINO
    Write-Host "[-] Creazione scudo di sistema (Restore Point)..." -ForegroundColor Yellow
    Checkpoint-Computer -Description "MAESTRO_ULTIMATE_BACKUP" -RestorePointType "MODIFY_SETTINGS" -ErrorAction SilentlyContinue

    if ($c1.Checked) {
        Write-Host "[-] Sblocco Potenza Nucleo..." -ForegroundColor Cyan
        powercfg -duplicatescheme e9a42b02-d5df-448d-aa00-03f14749eb61 | Out-Null
        powercfg -setactive e9a42b02-d5df-448d-aa00-03f14749eb61 | Out-Null
    }

    if ($c4.Checked) {
        Write-Host "[-] Ricalibrazione Input Latenza..." -ForegroundColor Cyan
        reg add "HKLM\SYSTEM\CurrentControlSet\Services\mouclass\Parameters" /v "MouseDataQueueSize" /t REG_DWORD /d 20 /f | Out-Null
        reg add "HKLM\SYSTEM\CurrentControlSet\Services\kbdclass\Parameters" /v "KeyboardDataQueueSize" /t REG_DWORD /d 20 /f | Out-Null
    }

    if ($c9.Checked) {
        Write-Host "[-] ESECUZIONE MASSACRO PROCESSI..." -ForegroundColor Red
        # Disabilita i servizi pesanti
        $SvcToKill = @("SysMain", "DiagTrack", "dmwappushservice", "WbioSrvc", "MapsBroker", "XblAuthManager", "XblGameSave", "XboxNetApiSvc", "Spooler")
        foreach ($s in $SvcToKill) {
            Write-Host "   > Terminando: $s" -ForegroundColor DarkGray
            Stop-Service -Name $s -Force | Out-Null
            Set-Service -Name $s -StartupType Disabled | Out-Null
        }
        # Disabilita Scheduled Tasks (La vera chicca)
        Get-ScheduledTask -TaskName "Consolidator", "ProgramDataUpdater", "Proxy" | Disable-ScheduledTask | Out-Null
    }

    if ($c7.Checked) {
        Write-Host "[-] Incenerimento Telemetria di Stato..." -ForegroundColor Yellow
        reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\DataCollection" /v "AllowTelemetry" /t REG_DWORD /d 0 /f | Out-Null
    }

    Write-Host "`n[COMPLETATO]: IL PC E' STATO REVISIONATO. RIAVVIA PER IL DECOLLO." -ForegroundColor Lime
    [System.Windows.Forms.MessageBox]::Show("Sistema Ottimizzato! Hai appena installato il potere sul tuo PC.", "The Maestro Omni-Optimizer")
})

$form.Controls.Add($btnRun)
$form.ShowDialog() | Out-Null
