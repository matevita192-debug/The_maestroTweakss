Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

# Controllo Amministratore
$currentPrincipal = New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())
if (-not $currentPrincipal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    [System.Windows.Forms.MessageBox]::Show("Per favore, esegui PowerShell come AMMINISTRATORE per applicare i tweak!", "Errore Permessi")
    return
}

$form = New-Object System.Windows.Forms.Form
$form.Text = "MATE PERFORMANCE TOOL V2"
$form.Size = New-Object System.Drawing.Size(400,550)
$form.StartPosition = "CenterScreen"
$form.BackColor = [System.Drawing.Color]::FromArgb(25, 25, 25)

# Titolo
$label = New-Object System.Windows.Forms.Label
$label.Text = "MATE TWEAKS"
$label.Font = New-Object System.Drawing.Font("Segoe UI", 22, [System.Drawing.FontStyle]::Bold)
$label.ForeColor = [System.Drawing.Color]::Cyan
$label.Size = New-Object System.Drawing.Size(300, 50)
$label.Location = New-Object System.Drawing.Point(50, 20)
$label.TextAlign = "MiddleCenter"
$form.Controls.Add($label)

# --- CHECKBOXES ---
$fontCheck = New-Object System.Drawing.Font("Segoe UI", 12)

$chkFPS = New-Object System.Windows.Forms.CheckBox
$chkFPS.Text = "Boost FPS (Ultimate Power)"
$chkFPS.ForeColor = "White"
$chkFPS.Font = $fontCheck
$chkFPS.Size = New-Object System.Drawing.Size(300, 30)
$chkFPS.Location = New-Object System.Drawing.Point(50, 100)
$form.Controls.Add($chkFPS)

$chkLag = New-Object System.Windows.Forms.CheckBox
$chkLag.Text = "Reduce Input Delay"
$chkLag.ForeColor = "White"
$chkLag.Font = $fontCheck
$chkLag.Size = New-Object System.Drawing.Size(300, 30)
$chkLag.Location = New-Object System.Drawing.Point(50, 150)
$form.Controls.Add($chkLag)

$chkClean = New-Object System.Windows.Forms.CheckBox
$chkClean.Text = "Clean Temp Files"
$chkClean.ForeColor = "White"
$chkClean.Font = $fontCheck
$chkClean.Size = New-Object System.Drawing.Size(300, 30)
$chkClean.Location = New-Object System.Drawing.Point(50, 200)
$form.Controls.Add($chkClean)

# --- TASTO APPLY ---
$btnApply = New-Object System.Windows.Forms.Button
$btnApply.Text = "APPLY TWEAKS"
$btnApply.Size = New-Object System.Drawing.Size(200, 60)
$btnApply.Location = New-Object System.Drawing.Point(100, 350)
$btnApply.FlatStyle = "Flat"
$btnApply.ForeColor = "Black"
$btnApply.BackColor = [System.Drawing.Color]::Cyan
$btnApply.Font = New-Object System.Drawing.Font("Segoe UI", 12, [System.Drawing.FontStyle]::Bold)

$btnApply.Add_Click({
    $actions = 0
    
    if ($chkFPS.Checked) {
        powercfg -duplicatescheme e9a42b02-d5df-448d-aa00-03f14749eb61 | Out-Null
        powercfg -setactive e9a42b02-d5df-448d-aa00-03f14749eb61
        $actions++
    }
    
    if ($chkLag.Checked) {
        Set-ItemProperty -Path "HKCU:\Control Panel\Mouse" -Name "MouseSpeed" -Value 0
        Set-ItemProperty -Path "HKLM:\SYSTEM\CurrentControlSet\Services\mouclass\Parameters" -Name "MouseDataQueueSize" -Value 20
        $actions++
    }
    
    if ($chkClean.Checked) {
        Remove-Item -Path "$env:TEMP\*" -Recurse -Force -ErrorAction SilentlyContinue
        $actions++
    }
    
    if ($actions -gt 0) {
        [System.Windows.Forms.MessageBox]::Show("Tweak applicati con successo! Riavvia il PC.", "Completato")
    } else {
        [System.Windows.Forms.MessageBox]::Show("Seleziona almeno un'opzione!", "Attenzione")
    }
})
$form.Controls.Add($btnApply)

$form.ShowDialog()
