<# 
======================================================================
      MAESTRO OMNI-OPTIMIZER: THE TITUS DEFINITIVE 2026
======================================================================
#>

# --- AUTO-ADMIN ELEVATION ---
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process powershell.exe "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`"" -Verb RunAs
    exit
}

Add-Type -AssemblyName System.Windows.Forms, System.Drawing

$form = New-Object System.Windows.Forms.Form
$form.Text = "MAESTRO OPTIMIZER | FULL TITUS SET"
$form.Size = New-Object System.Drawing.Size(900, 850)
$form.BackColor = [System.Drawing.Color]::FromArgb(20, 20, 20)
$form.ForeColor = [System.Drawing.Color]::White
$form.StartPosition = "CenterScreen"

# --- TITOLO CLASSICO ---
$lblHeader = New-Object System.Windows.Forms.Label
$lblHeader.Text = "WINDOWS OPTIMIZATION PANEL"
$lblHeader.Font = New-Object System.Drawing.Font("Segoe UI", 18, [System.Drawing.FontStyle]::Bold)
$lblHeader.TextAlign = "MiddleCenter"; $lblHeader.Size = New-Object System.Drawing.Size(900, 50); $lblHeader.ForeColor = [System.Drawing.Color]::DeepSkyBlue
$form.Controls.Add($lblHeader)

# --- CONTROLLO SCHEDE ---
$tabs = New-Object System.Windows.Forms.TabControl
$tabs.Location = New-Object System.Drawing.Point(30, 70); $tabs.Size = New-Object System.Drawing.Size(820, 600)
$form.Controls.Add($tabs)

function Add-TitusPage($name) {
    $p = New-Object System.Windows.Forms.TabPage; $p.Text = $name; $p.BackColor = [System.Drawing.Color]::FromArgb(40, 40, 40)
    $tabs.TabPages.Add($p); return $p
}

$t1 = Add-TitusPage "Essentials"
$t2 = Add-TitusPage "Gaming/Advanced"

function Add-Chk($txt, $y, $p) {
    $c = New-Object System.Windows.Forms.CheckBox; $c.Text = $txt; $c.Location = New-Object System.Drawing.Point(30, $y)
    $c.Size = New-Object System.Drawing.Size(700, 30); $c.Font = New-Object System.Drawing.Font("Consolas", 10)
    $p.Controls.Add($c); return $c
}

# --- LISTA TWEAK (SET COMPLETO TITUS) ---
$c_tele = Add-Chk "Disable Telemetry, Tracking & Data Collection" 30 $t1
$c_hiber = Add-Chk "Disable Hibernation (Delete hiberfil.sys)" 70 $t1
$c_uac = Add-Chk "Disable UAC (User Account Control)" 110 $t1
$c_edge = Add-Chk "Disable Edge Background Processes" 150 $t1
$c_maint = Add-Chk "Disable Automatic Maintenance Tasks" 190 $t1
$c_storage = Add-Chk "Disable Storage Sense & Temp File Collection" 230 $t1

$c_gpuprio = Add-Chk "Force GPU Priority (HAGS + Game Mode Reg)" 30 $t2
$c_dvr = Add-Chk "Disable GameDVR & Power Throttling" 70 $t2
$c_net = Add-Chk "Optimize Network (Disable Nagle's & Throttling)" 110 $t2
$c_ram = Add-Chk "Optimize RAM (Disable Paging Executive)" 150 $t2
$c_svc = Add-Chk "Kill Bloatware Services (Print, Fax, Maps, Xbox)" 190 $t2

# --- TASTO ESECUZIONE ---
$btn = New-Object System.Windows.Forms.Button
$btn.Text = "APPLY ALL TWEAKS"; $btn.Location = New-Object System.Drawing.Point(250, 700)
$btn.Size = New-Object System.Drawing.Size(400, 60); $btn.BackColor = [System.Drawing.Color]::DeepSkyBlue
$btn.FlatStyle = "Flat"; $btn.Font = New-Object System.Drawing.Font("Segoe UI", 12, [System.Drawing.FontStyle]::Bold)

$btn.Add_Click({
    Write-Host "[*] Inizio Ottimizzazione Totale..." -ForegroundColor Cyan

    # 1. TELEMETRIA E PRIVACY
    if ($c_tele.Checked) {
        Write-Host "[-] Rimuovendo Telemetria..."
        reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\DataCollection" /v "AllowTelemetry" /t REG_DWORD /d 0 /f | Out-Null
        reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\DataCollection" /v "AllowTelemetry" /t REG_DWORD /d 0 /f | Out-Null
        Get-Service "DiagTrack", "dmwappushservice" -ErrorAction SilentlyContinue | Stop-Service -Force | Set-Service -StartupType Disabled
    }

    # 2. GAMING & GPU
    if ($c_gpuprio.Checked) {
        Write-Host "[-] Ottimizzando GPU..."
        reg add "HKLM\SYSTEM\CurrentControlSet\Control\GraphicsDrivers" /v "HwSchMode" /t REG_DWORD /d 2 /f | Out-Null
        reg add "HKLM\SOFTWARE\Microsoft\PolicyManager\default\ApplicationManagement\AllowGameDVR" /v "value" /t REG_DWORD /d 0 /f | Out-Null
    }

    # 3. RETE (Nagle's Algorithm)
    if ($c_net.Checked) {
        Write-Host "[-] Ottimizzando Rete..."
        reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile" /v "NetworkThrottlingIndex" /t REG_DWORD /d 0xFFFFFFFF /f | Out-Null
        reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile" /v "SystemResponsiveness" /t REG_DWORD /d 0 /f | Out-Null
    }

    # 4. RAM & KERNEL
    if ($c_ram.Checked) {
        reg add "HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" /v "DisablePagingExecutive" /t REG_DWORD /d 1 /f | Out-Null
    }

    # 5. SERVIZI (Il "massacro" di Titus)
    if ($c_svc.Checked) {
        $svcs = @("Spooler", "Fax", "MapsBroker", "XblAuthManager", "XblGameSave", "XboxNetApiSvc")
        foreach ($s in $svcs) {
            Get-Service $s -ErrorAction SilentlyContinue | Stop-Service -Force | Set-Service -StartupType Disabled
        }
    }

    # 6. IBERNAZIONE
    if ($c_hiber.Checked) { powercfg -h off }

    [System.Windows.Forms.MessageBox]::Show("Rituale completato! Riavvia il PC, Mate.", "Maestro Optimizer")
})

$form.Controls.Add($btn)
$form.ShowDialog()
